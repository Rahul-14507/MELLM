c static int binarySearch(int[] arr, int target) {\u001b[0m                                                                                                                                                                        \u001b[32m‚îÇ\u001b[0m\r\n\u001b[32m‚îÇ\u001b[0m \u001b[1;37m        int left = 0;\u001b[0m                                                                                                                                                                                                              \u001b[32m‚îÇ\u001b[0m\r\n\u001b[32m‚îÇ\u001b[0m \u001b[1;37m        int right = arr.length - 1;\u001b[0m                                                                                                                                                                                                \u001b[32m‚îÇ\u001b[0m\r\n\u001b[32m‚îÇ\u001b[0m                                                                                                                                                                                                                                    \u001b[32m‚îÇ\u001b[0m\r\n\u001b[32m‚îÇ\u001b[0m \u001b[1;37m        while (left <= right) {\u001b[0m                                                                                                                                                                                                    \u001b[32m‚îÇ\u001b[0m\r\n\u001b[32m‚îÇ\u001b[0m \u001b[1;37m            int mid = left + (right - left) / 2;\u001b[0m                                                                                                                                                                                   \u001b[32m‚îÇ\u001b[0m\r\n\u001b[32m‚îÇ\u001b[0m                                                                                                                                                                                                                                    \u001b[32m‚îÇ\u001b[0m\r\n\u001b[32m‚îÇ\u001b[0m \u001b[1;37m            if (arr[mid] == target) {\u001b[0m                                                                                                                                                                                              \u001b[32m‚îÇ\u001b[0m\r\n\u001b[32m‚îÇ\u001b[0m \u001b[1;37m                return mid;\u001b[0m                                                                                                                                                                                                      "]
